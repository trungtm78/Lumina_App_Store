{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumina.io/schemas/app-config.json",
  "title": "Lumina App Config",
  "description": "Configuration schema for Lumina App Store addons",
  "type": "object",
  "required": [
    "app_id",
    "name",
    "version",
    "description",
    "description_short",
    "category",
    "company",
    "ai_model",
    "target",
    "permissions"
  ],
  "properties": {
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 100,
      "description": "Unique slug identifier for the app"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Display name of the app"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version (X.Y.Z)"
    },
    "description": {
      "type": "string",
      "maxLength": 5000,
      "description": "Full description of the app"
    },
    "description_short": {
      "type": "string",
      "maxLength": 120,
      "description": "Short description for card display"
    },
    "category": {
      "type": "string",
      "enum": [
        "Chat",
        "Analytics",
        "Integration",
        "HR",
        "Finance",
        "Productivity",
        "Security",
        "DevTools",
        "Other"
      ]
    },
    "company": {
      "type": "object",
      "required": ["name", "website", "support_email", "license"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "website": { "type": "string", "format": "uri" },
        "support_email": { "type": "string", "format": "email" },
        "license": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "creator": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "github": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "ai_model": {
      "type": "object",
      "required": ["provider", "model", "fallback"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["anthropic", "openai", "gemini", "local"]
        },
        "model": { "type": "string", "minLength": 1 },
        "fallback": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["systems", "modules", "min_version"],
      "properties": {
        "systems": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["core", "plus", "storage", "care", "all"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "chat",
              "dashboard",
              "deep_search",
              "workflow",
              "reporting",
              "ticketing",
              "knowledge_base",
              "file_manager"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "min_version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(read|write|execute|external):[a-z_]+$"
      },
      "minItems": 0
    },
    "auto_activate": {
      "type": "boolean",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
